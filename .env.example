# Copy this file to .env at the repository root and fill in real values.
# Both backend/scripts/init_db.py and backend/app/config/settings.py load
# this file automatically.

# --- Shared MySQL database ---
# perennia-auth and perennia-access apply their own schema.sql files to this
# same database (see backend/scripts/init_db.py). Their tables do not conflict.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=abc_enterprises

# --- perennia-auth ---
# Long, random secret used to sign access/refresh tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SIGNING_SECRET=change-me-to-a-long-random-value

# perennia-auth exposes this option, but does not currently enforce it in its
# own authentication logic - new accounts must call /api/auth/verify-email
# regardless of this setting. Kept here for forward compatibility.
REQUIRE_EMAIL_VERIFICATION=false

# --- Application ---
# Comma-separated list of origins allowed to call this API (the frontend dev
# server, and/or wherever the frontend is deployed).
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# --- Quotations workflow ---
# Role codes (from app/permissions/definitions.py ROLES: employee, manager,
# administrator) allowed to create, and to approve, a quotation. Only the
# identity holding QUOTATION_CREATOR_ROLE can POST /api/quotations, and only
# the identity holding QUOTATION_APPROVER_ROLE can
# POST /api/quotations/{id}/approve - enforced by the quotations.create /
# quotations.approve permissions, granted to these roles at startup.
QUOTATION_CREATOR_ROLE=manager
QUOTATION_APPROVER_ROLE=administrator
